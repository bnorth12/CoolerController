// Copy this file to secrets.h and fill in your own values.
// secrets.h is listed in .gitignore so your credentials will never be committed.

#ifndef SECRETS_H
#define SECRETS_H

// WiFi credentials (used as the default STA-mode connection before captive portal saves new ones)
#define WLAN_SSID  "your_wifi_ssid"
#define WLAN_PASS  "your_wifi_password"

// Adafruit IO credentials – obtain from https://io.adafruit.com/
#define AIO_SERVER      "io.adafruit.com"
#define AIO_SERVERPORT  1883
#define AIO_USERNAME    "your_adafruit_io_username"
#define AIO_KEY         "your_adafruit_io_key"

#endif // SECRETS_H
